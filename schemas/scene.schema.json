{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Synesthesia Scene Configuration",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of the scene."
    },
    "description": {
      "type": "string",
      "description": "A description of the scene."
    },
    "author": {
      "type": "string",
      "description": "The author of the scene."
    },
    "credits": {
      "type": "string",
      "description": "Credits for the scene."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Tags for the scene."
    },
    "controls": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["slider", "toggle", "button", "xy", "color", "list"]
          },
          "default": { "type": ["number", "boolean", "array"] },
          "min": { "type": "number" },
          "max": { "type": "number" }
        },
        "required": ["name", "type"]
      }
    },
    "images": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "path": { "type": "string" }
        },
        "required": ["name", "path"]
      }
    },
    "audioPasses": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "samples": { "type": "integer" }
        }
      }
    }
  }
}
